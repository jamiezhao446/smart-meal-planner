# 前端（Vite 构建时注入）
# 本地开发：先 npm run dev:agent，再设此地址
VITE_AGENT_API_URL=http://127.0.0.1:5173/api/agent

# 生产：填 Vercel 部署后的完整 URL，例如
# VITE_AGENT_API_URL=https://smart-meal-planner-agent.vercel.app/api/agent

# 后端 Agent API（仅 Vercel / 本地 server，勿提交到仓库）
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
# 国内可用兼容接口，例如 DeepSeek：
# OPENAI_BASE_URL=https://api.deepseek.com/v1
# OPENAI_MODEL=deepseek-chat

# 可选：额外允许的 CORS 来源（逗号分隔）
# ALLOWED_ORIGINS=https://your-domain.com
